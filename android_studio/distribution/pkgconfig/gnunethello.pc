prefix=/home/user/ndk-sysroot/arm64-v8a/gnunet
includedir=${prefix}/include
libdir=${prefix}/lib

Name: gnunethello
Description: Helper library for handling GNUnet HELLO messages
URL: https://www.gnunet.org
Version: show
Requires.private: gnunetutil, libgcrypt, libsodium >= 1.0.18
Libs: -L${prefix}/lib -lgnunethello
Cflags: -I${includedir}
