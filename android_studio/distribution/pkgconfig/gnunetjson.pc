prefix=/home/user/ndk-sysroot/arm64-v8a/gnunet
includedir=${prefix}/include
libdir=${prefix}/lib

Name: gnunetjson
Description: Library for JSON de/serialization
URL: https://www.gnunet.org
Version: show
Requires.private: gnunetutil, libsodium >= 1.0.18, libgcrypt, jansson
Libs: -L${prefix}/lib -lgnunetjson
Libs.private: -lz
Cflags: -I${includedir}
