prefix=/home/user/AndroidStudioProjects/gnunet-android/android_studio/distribution/libgnunet/lib/arm64-v8a
includedir=${prefix}/include
libdir=${prefix}

Name: gnunetutil
Description: Provides miscellaneous utility functions and API for GNUnet
URL: https://www.gnunet.org
Version: 0.24.1-19-gf8d2003a0
Requires.private: libgmp, libmicrohttpd, libsodium >= 1.0.18, libgcrypt, libunistring, libltdl, libidn
Libs: -L${prefix} -lgnunetutil
Libs.private: -lz
Cflags: -I${includedir}
